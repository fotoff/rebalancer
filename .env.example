# WalletConnect (required for RainbowKit)
# Get from https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id

# Alchemy (for portfolio scan - all tokens with balance on Base)
# Get from https://dashboard.alchemy.com/ - free tier
ALCHEMY_API_KEY=

# GoPlus Security (scam token detection - optional, free tier ~30 req/min)
# Get from https://gopluslabs.io/
GOPLUS_API_KEY=

# RebalancerVault address (after deploy)
NEXT_PUBLIC_VAULT_ADDRESS=0x...

# Deploy (for packages/contracts/)
PRIVATE_KEY=0x...
BASE_RPC_URL=https://mainnet.base.org
EXECUTOR_ADDRESS=0x...

# Internal API key for trigger-checker authentication
INTERNAL_API_KEY=

# Gelato (optional - for automatic rebalancing)
GELATO_API_KEY=

# AI Advisor (optional - if running ai-advisor service)
AI_ADVISOR_URL=http://127.0.0.1:8000
AI_SERVICE_SECRET=change-me-to-random-secret

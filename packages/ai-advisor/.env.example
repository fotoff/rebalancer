# AI Advisor Configuration
# All variables prefixed with AI_

# Service
AI_HOST=127.0.0.1
AI_PORT=8000
AI_DEBUG=false
AI_LOG_LEVEL=info

# Auth — shared secret between Next.js and ai-advisor (generate a random string)
AI_SERVICE_SECRET=change-me-to-random-secret

# Next.js internal URL
AI_NEXTJS_BASE_URL=http://127.0.0.1:3001

# Chain
AI_CHAIN_ID=8453
AI_VAULT_ADDRESS=0xf950dA9A11A3D7701470e4F37a68A5e6bC9b177C

# LLM (optional — works without it using template explanations)
AI_OPENAI_API_KEY=
AI_LLM_MODEL=gpt-4o-mini
AI_LLM_ENABLED=true

# Policy defaults (can be overridden per-request via user_constraints)
AI_MAX_SLIPPAGE_BPS=100
AI_MAX_GAS_USD=10.0
AI_MIN_LIQUIDITY_SCORE=0.1
AI_MIN_EDGE_AFTER_COST_BPS=10.0
AI_MAX_TRADE_PCT=30.0
AI_COOLDOWN_MINUTES=60
AI_MAX_DAILY_TURNOVER_PCT=200.0
AI_DATA_STALENESS_SECONDS=120
AI_SNAPSHOT_CACHE_TTL=15
